# Exemple de configuration par variables d'environnement.
# Copiez ce fichier en `.env` et adaptez les valeurs. Toutes les variables sont
# préfixées par TRIAGE_ (cf. src/triage/config.py).

# Modèle de base (surchargeable pour tester un modèle plus petit en CI)
TRIAGE_BASE_MODEL=Qwen/Qwen3-1.7B-Base

# Backend d'inférence : "transformers" (local) ou "vllm" (production)
TRIAGE_INFERENCE_BACKEND=transformers

# Chemin du modèle fusionné (backend transformers)
TRIAGE_MODEL_PATH=models/qwen3-triage-merged

# Serveur vLLM (backend vllm)
TRIAGE_VLLM_BASE_URL=http://localhost:8000/v1
TRIAGE_VLLM_MODEL_NAME=chsa-triage

# Génération
TRIAGE_MAX_NEW_TOKENS=512
TRIAGE_TEMPERATURE=0.3

# Journal d'audit
TRIAGE_AUDIT_LOG_PATH=logs/audit.log
